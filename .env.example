# Required for caption generation
ANTHROPIC_API_KEY=

# TikTok — run: cutter auth tiktok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=

# Instagram — run: cutter auth instagram
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# WhatsApp approval (via Twilio)
# Sign up at twilio.com, enable the WhatsApp Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio WhatsApp sandbox number, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number in E.164 format, e.g. whatsapp:+447700900000
TWILIO_WHATSAPP_TO=

# S3 temporary storage for Instagram video upload
# The bucket needs to allow public-read or presigned URL access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
