# Required for caption generation
ANTHROPIC_API_KEY=

# TikTok — run: cutter auth tiktok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=

# Instagram — run: cutter auth instagram
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# WhatsApp approval (via Twilio)
# Sign up at twilio.com, enable the WhatsApp Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio WhatsApp sandbox number, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number in E.164 format, e.g. whatsapp:+447700900000
TWILIO_WHATSAPP_TO=

# Preview server for WhatsApp approval
# Clips are SCP'd here, served over HTTPS for review, then deleted.
# Any server you can SSH/SCP into and that serves files publicly will work.
PREVIEW_HOST=your-server.example.com
PREVIEW_USER=root
PREVIEW_WEBROOT=/var/www/cutter/media
PREVIEW_BASE_URL=https://your-server.example.com/cutter/media
PREVIEW_SSH_KEY=~/.ssh/id_ed25519

# S3 temporary storage for Instagram video upload
# The bucket needs to allow public-read or presigned URL access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
